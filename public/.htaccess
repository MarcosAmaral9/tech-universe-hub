# VicioCode .htaccess — segurança e HTTPS

# ── Força HTTPS ───────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Redireciona HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP_HOST} !^localhost
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ── Security Headers ──────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  # Permite popup OAuth do Google (login) sem quebrar isolamento
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  # Permite que assets sejam servidos a iframes do AdSense
  Header always set Cross-Origin-Resource-Policy "cross-origin"
  # Remove cabeçalhos que expõem informações do servidor
  Header always unset X-Powered-By
  Header always unset Server

  # Service Worker NUNCA pode ficar cacheado (senão SW antigo fica preso)
  <FilesMatch "^(sw|service-worker|push-handler|registerSW)\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  <FilesMatch "^(manifest\.webmanifest|manifest\.json)$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# ── SPA: serve index.html para rotas React ────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Prioriza .html estático (posts e regiões gerados pelo build)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ $1.html [L]
  # Serve arquivos estáticos diretamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Fallback: todas as rotas → index.html (SPA)
  RewriteRule ^ index.html [L]
</IfModule>

# ── Cache de assets estáticos ─────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# ── Bloqueia acesso a arquivos sensíveis ──────────────────────
<FilesMatch "\.(env|log|sh|bak|sql|git|gitignore)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ── Bloqueia listagem de diretórios ───────────────────────────
Options -Indexes
